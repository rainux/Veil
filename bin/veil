#!/bin/sh
# Launch Veil with all arguments passed to the embedded nvim.
# Symlink this to a directory in your PATH:
#   ln -s /Applications/Veil.app/Contents/bin/veil ~/.local/bin/veil

# Resolve the real path of this script (handles symlinks)
self_path="$0"
while [ -L "$self_path" ]; do
    dir="$(cd "$(dirname "$self_path")" && pwd -P)"
    self_path="$(readlink "$self_path")"
    [ "${self_path#/}" = "$self_path" ] && self_path="$dir/$self_path"
done
binary="$(cd "$(dirname "$self_path")/../MacOS" 2>/dev/null && pwd -P)/Veil"

if ! [ -x "$binary" ]; then
    # Fallback: standard install location
    binary="/Applications/Veil.app/Contents/MacOS/Veil"
fi
if ! [ -x "$binary" ]; then
    # Fallback: Spotlight search for exact bundle ID
    app_path=$(mdfind "kMDItemCFBundleIdentifier == 'org.1b2c.Veil'" 2>/dev/null | head -1)
    if [ -n "$app_path" ]; then
        binary="$app_path/Contents/MacOS/Veil"
    fi
fi
if ! [ -x "$binary" ]; then
    echo "Cannot find Veil executable." >&2
    exit 1
fi

# Detect invocation name for vimdiff mode
name="$(basename "$0")"
opts=""
case "$name" in
    *vimdiff) opts="-d" ;;
esac

# Launch in background and exit immediately.
# PWD is inherited from the parent shell so nvim opens files correctly.
"$binary" $opts "$@" &
